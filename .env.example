# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/self_media?schema=public

# === Crypto ===
# 32-byte hex (64 hex chars). Generate with: node scripts/gen-secrets.mjs
MASTER_KEY=

# === Auth ===
# bcrypt hash of admin password. Generate with: node scripts/gen-secrets.mjs <password>
# IMPORTANT: each `$` in the hash MUST be escaped as `\$` so Next.js's env loader
# (dotenv-expand) doesn't expand `$2b`, `$12`, etc. as empty variables.
# Example: ADMIN_PASSWORD_HASH=\$2b\$12\$abc...xyz
# The gen-secrets.mjs script outputs the escaped form automatically.
ADMIN_PASSWORD_HASH=
# 32-byte base64. Generate with: node scripts/gen-secrets.mjs
SESSION_SECRET=

# === Storage ===
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# === COS (used in plan 3 v0.2; leave blank for v0.1) ===
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=

# === Runtime ===
NODE_ENV=development
